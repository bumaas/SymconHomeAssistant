{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Home Assistant Connection",
      "expanded": true,
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "MQTTBaseTopic",
          "caption": "MQTT Base Topic"
        },
        {
          "type": "Label",
          "caption": "Note: Home Assistant must have mqtt_statestream enabled and base_topic must match MQTT Base Topic."
        },
        {
          "type": "ValidationTextBox",
          "name": "HAUrl",
          "caption": "HA URL"
        },
        {
          "type": "ValidationTextBox",
          "name": "HAToken",
          "caption": "Long-Lived Access Token"
        },
        {
          "type": "Label",
          "caption": "Hint: Create the token in Home Assistant under Profile > Security > Long-Lived Access Tokens."
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Expert",
      "items": [
        {
          "type": "CheckBox",
          "name": "UseRestForSetTopics",
          "caption": "Use REST for */set topics",
          "visible": false
        },
        {
          "type": "NumberSpinner",
          "name": "RestAckTimeoutSec",
          "caption": "REST ack timeout (s)",
          "minimum": 0,
          "maximum": 60,
          "visible": false
        },
        {
          "type": "CheckBox",
          "name": "EnableExpertDebug",
          "caption": "Enable extended debug output"
        },
        {
          "type": "CheckBox",
          "name": "EnablePerformanceLog",
          "caption": "Enable performance timing (debug channel 'Performance')"
        },
        {
          "type": "CheckBox",
          "name": "EnableTopicStatistics",
          "caption": "Enable topic statistics (debug channel 'TopicStats')"
        },
        {
          "type": "NumberSpinner",
          "name": "TopicStatisticsIntervalMinutes",
          "caption": "Topic statistics interval (minutes)",
          "minimum": 1,
          "maximum": 1440
        },
        {
          "type": "NumberSpinner",
          "name": "OutputBufferSize",
          "caption": "Output buffer (MB)",
          "minimum": 0,
          "maximum": 100,
          "value": 10,
          "visible": false
        },
        {
          "type": "Select",
          "name": "DebugResponseFormat",
          "caption": "Debug response format",
          "options": [
            {
              "caption": "JSON compact",
              "value": "json_compact"
            },
            {
              "caption": "JSON pretty",
              "value": "json_pretty"
            },
            {
              "caption": "Raw",
              "value": "raw"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "ExpansionPanel",
      "caption": "Diagnostics",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "name": "LastMQTTMessage",
          "caption": "Last MQTT message: never"
        },
        {
          "type": "Label",
          "name": "DiagParent",
          "caption": "MQTT parent: -"
        },
        {
          "type": "Label",
          "name": "DiagBaseTopic",
          "caption": "MQTT base topic: -"
        },
        {
          "type": "Label",
          "name": "DiagRest",
          "caption": "Last REST error: none"
        },
        {
          "type": "Label",
          "name": "DiagRestResponse",
          "caption": "Last REST response: none"
        },
        {
          "type": "Label",
          "name": "DiagRestTimeout",
          "caption": "Last REST timeout: none"
        }
      ]
    }
  ],
  "status": [
    {
      "code": 201,
      "icon": "error",
      "caption": "No active MQTT parent connected."
