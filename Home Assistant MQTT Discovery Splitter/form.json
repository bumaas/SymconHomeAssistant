{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "MQTT Discovery",
      "expanded": true,
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "MQTTDiscoveryPrefix",
          "caption": "MQTT Discovery Prefix"
        },
        {
          "type": "ValidationTextBox",
          "name": "SourceMode",
          "caption": "Source mode"
        },
        {
          "type": "Label",
          "name": "BundleBasePathInfo",
          "caption": "Default bundle path: -"
        },
        {
          "type": "ValidationTextBox",
          "name": "BundlePath",
          "caption": "Bundle file or path"
        },
        {
          "type": "CheckBox",
          "name": "BundleCurrentSessionOnly",
          "caption": "Use only current session records from bundle"
        },
        {
          "type": "CheckBox",
          "name": "ReplayTopicsOnApply",
          "caption": "Replay cached bundle topics on ApplyChanges"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Expert",
      "items": [
        {
          "type": "CheckBox",
          "name": "EnableExpertDebug",
          "caption": "Enable extended debug output"
        },
        {
          "type": "NumberSpinner",
          "name": "OutputBufferSize",
          "caption": "Output buffer (MB)",
          "minimum": 0,
          "maximum": 100,
          "value": 10,
          "visible": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "ExpansionPanel",
      "caption": "Diagnostics",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "name": "DiagInstance",
          "caption": "Instance: - | Status -"
        },
        {
          "type": "Label",
          "name": "DiagSource",
          "caption": "Source: MQTT"
        },
        {
          "type": "Label",
          "name": "LastMQTTMessage",
          "caption": "Last MQTT message: never"
        },
        {
          "type": "Label",
          "name": "DiagParent",
          "caption": "MQTT Parent: -"
        },
        {
          "type": "Label",
          "name": "DiagSession",
          "caption": "MQTT Session: no active session"
        },
        {
          "type": "Label",
          "name": "DiagBundle",
          "caption": "Bundle: inactive"
        },
        {
          "type": "PopupAlert",
          "name": "DiagDiscoveryAlert",
          "visible": false,
          "popup": {
            "closeCaption": "OK",
            "items": [
              {
                "type": "Label",
                "caption": "Discovery configs from previous MQTT sessions are still cached. Reconnect/restart the producer and reapply Splitter and Device."
              }
            ]
          }
        },
        {
          "type": "Label",
          "name": "DiagDiscovery",
          "caption": "MQTT Discovery Prefix: - | Discovery configs total/current/stale: 0/0/0"
        },
        {
          "type": "Label",
          "name": "DiagDiscoveryPreview",
          "caption": "Stale discovery topics: -"
        },
        {
          "type": "Label",
          "name": "DiagTopicPayloads",
          "caption": "Referenced runtime topics total/current/stale/missing: 0/0/0/0"
        },
        {
          "type": "Label",
          "name": "DiagTopicPreview",
          "caption": "Missing/stale runtime topics: -"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Export",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "caption": "Exports discovery configs, referenced MQTT topics, session data, freshness data, and missing-topic metadata as a JSON bundle."
        },
        {
          "type": "RowLayout",
          "items": [
            {
              "type": "Button",
              "name": "ButtonReconnectMqttIo",
              "caption": "Reconnect MQTT IO",
              "onClick": "HAMD_ReconnectMqttParent($id);"
            },
            {
              "type": "Button",
              "name": "ButtonReloadBundle",
              "caption": "Reload bundle",
              "onClick": "IPS_ApplyChanges($id);"
            },
            {
              "type": "Button",
              "name": "ButtonReplayBundleTopics",
              "caption": "Replay bundle topics",
              "onClick": "HAMD_ReplayBundleTopicsToChildren($id);"
            }
          ]
        },
        {
          "type": "RowLayout",
          "items": [
            {
              "type": "Button",
              "caption": "Download discovery bundle",
              "download": "ha_mqtt_discovery_bundle.json",
              "onClick": "echo HAMD_ExportDiscoveryBundleDataUrl($id, true, false, false);"
            },
            {
              "type": "Button",
              "caption": "Download current session discovery bundle",
              "download": "ha_mqtt_discovery_bundle_current_session.json",
              "onClick": "echo HAMD_ExportDiscoveryBundleDataUrl($id, true, false, true);"
            }
          ]
        }
      ]
    }
  ],
  "status": [
    {
      "code": 201,
      "icon": "error",
      "caption": "No active MQTT parent connected."
    },
    {
      "code": 202,
      "icon": "error",
      "caption": "MQTT discovery prefix is empty."
    },
    {
      "code": 203,
      "icon": "error",
      "caption": "Bundle path is empty."
    },
    {
      "code": 204,
      "icon": "error",
      "caption": "Bundle could not be loaded or validated."
    }
  ]
}
