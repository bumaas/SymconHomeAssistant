{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Source",
      "expanded": true,
      "items": [
        {
          "type": "Select",
          "name": "SourceMode",
          "caption": "Source mode",
          "options": [
            {
              "caption": "MQTT",
              "value": "mqtt"
            },
            {
              "caption": "Bundle",
              "value": "bundle"
            }
          ]
        },
        {
          "type": "ValidationTextBox",
          "name": "MQTTDiscoveryPrefix",
          "caption": "MQTT Discovery Prefix"
        },
        {
          "type": "ValidationTextBox",
          "name": "BundlePath",
          "caption": "Bundle path"
        },
        {
          "type": "CheckBox",
          "name": "BundleCurrentSessionOnly",
          "caption": "Use only current session records from bundle"
        },
        {
          "type": "CheckBox",
          "name": "ReplayTopicsOnApply",
          "caption": "Replay cached bundle topics on ApplyChanges"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Expert",
      "items": [
        {
          "type": "CheckBox",
          "name": "EnableExpertDebug",
          "caption": "Enable extended debug output"
        },
        {
          "type": "NumberSpinner",
          "name": "OutputBufferSize",
          "caption": "Output buffer (MB)",
          "minimum": 0,
          "maximum": 100,
          "value": 10,
          "visible": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "ExpansionPanel",
      "caption": "Diagnostics",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "name": "DiagInstance",
          "caption": "Instance: - | Status -"
        },
        {
          "type": "Label",
          "name": "DiagSource",
          "caption": "Source: MQTT"
        },
        {
          "type": "Label",
          "name": "LastMQTTMessage",
          "caption": "Letzte MQTT-Message: nie"
        },
        {
          "type": "Label",
          "name": "DiagParent",
          "caption": "MQTT Parent: -"
        },
        {
          "type": "Label",
          "name": "DiagSession",
          "caption": "MQTT Session: keine aktive Session"
        },
        {
          "type": "Label",
          "name": "DiagBundle",
          "caption": "Bundle: nicht aktiv"
        },
        {
          "type": "Label",
          "name": "DiagDiscovery",
          "caption": "MQTT Discovery Prefix: - | Configs gesamt/aktuell/stale: 0/0/0"
        },
        {
          "type": "Label",
          "name": "DiagDiscoveryPreview",
          "caption": "Stale Discovery Topics: -"
        },
        {
          "type": "Label",
          "name": "DiagTopicPayloads",
          "caption": "Referenzierte Runtime Topics gesamt/aktuell/stale/fehlend: 0/0/0/0"
        },
        {
          "type": "Label",
          "name": "DiagTopicPreview",
          "caption": "Fehlende/Stale Runtime Topics: -"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Export",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "caption": "Exportiert Discovery-Configs, referenzierte MQTT-Topics sowie Session-, Freshness- und Missing-Topic-Metadaten als JSON-Bundle."
        },
        {
          "type": "RowLayout",
          "items": [
            {
              "type": "Button",
              "caption": "MQTT-IO reconnecten",
              "onClick": "HA_ReconnectMqttParent($id);"
            },
            {
              "type": "Button",
              "caption": "Bundle neu laden",
              "onClick": "IPS_ApplyChanges($id);"
            },
            {
              "type": "Button",
              "caption": "Bundle-Topics replayen",
              "onClick": "HA_ReplayBundleTopicsToChildren($id);"
            }
          ]
        },
        {
          "type": "RowLayout",
          "items": [
            {
              "type": "Button",
              "caption": "Discovery-Bundle herunterladen",
              "download": "ha_mqtt_discovery_bundle.json",
              "onClick": "echo HA_ExportDiscoveryBundleDataUrl($id, true, false, false);"
            },
            {
              "type": "Button",
              "caption": "Discovery-Bundle aktuelle Session herunterladen",
              "download": "ha_mqtt_discovery_bundle_current_session.json",
              "onClick": "echo HA_ExportDiscoveryBundleDataUrl($id, true, false, true);"
            }
          ]
        }
      ]
    }
  ],
  "status": [
    {
      "code": 201,
      "icon": "error",
      "caption": "Kein aktiver MQTT-Parent verbunden."
    },
    {
      "code": 202,
      "icon": "error",
      "caption": "MQTT Discovery Prefix ist leer."
    },
    {
      "code": 203,
      "icon": "error",
      "caption": "Bundle-Pfad ist leer."
    },
    {
      "code": 204,
      "icon": "error",
      "caption": "Bundle konnte nicht geladen oder validiert werden."
    }
  ]
}
