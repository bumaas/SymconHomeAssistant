{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "EntityID",
      "caption": "Entity ID"
    },
    {
      "type": "Label",
      "caption": "Dieses Modul konfiguriert sich automatisch basierend auf der angegebenen Entity ID aus Home Assistant."
    },
    {
      "type": "ExpansionPanel",
      "caption": "Expert",
      "items": [
        {
          "type": "CheckBox",
          "name": "EnableExpertDebug",
          "caption": "Enable extended debug output"
        },
        {
          "type": "CheckBox",
          "name": "ShowUnavailableEntitiesJson",
          "caption": "Show unavailable entities JSON"
        },
        {
          "type": "NumberSpinner",
          "name": "OutputBufferSize",
          "caption": "Output buffer (MB)",
          "minimum": 0,
          "maximum": 100,
          "value": 10
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Resolved Configuration",
      "items": [
        {
          "type": "Label",
          "name": "ResolvedName",
          "caption": "Resolved Name: "
        },
        {
          "type": "Label",
          "name": "ResolvedDomain",
          "caption": "Resolved Domain: "
        },
        {
          "type": "Label",
          "name": "ResolvedDeviceClass",
          "caption": "Resolved Device Class: "
        },
        {
          "type": "Label",
          "name": "ResolvedDeviceID",
          "caption": "Resolved Device ID: "
        },
        {
          "type": "Label",
          "name": "ResolvedArea",
          "caption": "Resolved Area: "
        },
        {
          "type": "Label",
          "name": "ResolvedAttributeCount",
          "caption": "Resolved Attribute Count: "
        },
        {
          "type": "List",
          "name": "ResolvedAttributes",
          "caption": "Resolved Attributes",
          "rowCount": 10,
          "add": false,
          "delete": false,
          "columns": [
            {
              "caption": "Key",
              "name": "Key",
              "width": "220px"
            },
            {
              "caption": "Value",
              "name": "Value",
              "width": "auto"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Label",
      "name": "CURRENT_FILTER",
      "caption": "Aktueller Filter (Regex):",
      "visible": false
    },
    {
      "type": "ExpansionPanel",
      "caption": "Diagnostics",
      "expanded": false,
      "items": [
        {
          "type": "Label",
          "name": "DiagLastMQTT",
          "caption": "Letzte MQTT-Message: nie"
        },
        {
          "type": "Label",
          "name": "DiagLastREST",
          "caption": "Letzter REST-Abruf: nie"
        },
        {
          "type": "Label",
          "name": "DiagEntityCount",
          "caption": "Entit\u00e4ten (aktiv): 0"
        }
      ]
    },
    {
      "type": "Button",
      "label": "Jetzt aktualisieren",
      "onClick": "HAE_UpdateConfiguration($id);"
    },
    {
      "type": "TestCenter"
    }
  ],
  "status": [
    {
      "code": 201,
      "icon": "error",
      "caption": "Kein kompatibler oder aktiver Parent verbunden"
    },
    {
      "code": 210,
      "icon": "error",
      "caption": "Entity not found"
    },
    {
      "code": 211,
      "icon": "error",
      "caption": "Entity invalid"
    }
  ]
}
